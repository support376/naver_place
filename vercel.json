{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "api/ai-analyze.js", "use": "@vercel/node" },
    { "src": "api/find-competitors.js", "use": "@vercel/node" },
    { "src": "api/place.js", "use": "@vercel/node" },
    { "src": "api/threads.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "api/index.py" },
    { "src": "/api/dashboard(.*)", "dest": "api/index.py" },
    { "src": "/api/ai-analyze", "dest": "api/ai-analyze.js" },
    { "src": "/api/find-competitors", "dest": "api/find-competitors.js" },
    { "src": "/api/place", "dest": "api/place.js" },
    { "src": "/api/threads", "dest": "api/threads.js" },
    { "src": "/(.+\\..+)", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
